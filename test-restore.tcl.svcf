	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.dec_rf_reg.odd_opcode_q[0:6]}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.dec_rf_reg.odd_instruction_type_q[0:2]}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.dec_rf_reg.odd_reg_write_q}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.rf_exec_reg.even_opcode_q[0:6]}]}
	} ]]
set id [waveform add -signals [subst  {
