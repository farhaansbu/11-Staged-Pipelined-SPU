	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.rf_exec_reg.odd_unit_id_q[0:2]}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.rf_exec_reg.odd_reg_write_q}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.rf_exec_reg.odd_write_addr_q[0:6]}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.exec_unit.flush_after}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.exec_unit.flush_all}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.hazard_detection.flush_if_id}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.hazard_detection.flush_id_rf}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.hazard_detection.flush_rf_ex}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.hazard_detection.flush_ex_1}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.hazard_detection.flush_even_2}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.rf.reg_file[29]}]}
	} ]]
set id [waveform add -signals [subst  {
	{simulator::[format {tbench.dut.rf.reg_file[0:127]}]}
	} ]]
waveform hierarchy collapse $id

waveform xview limits 0 125000ps

#
# Waveform Window Links
#

#
# Console windows
#
console set -windowname Console
window geometry Console 730x250+8+31

