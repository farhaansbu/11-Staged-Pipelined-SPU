database -open waves -into waves.shm -default
probe -create -shm tb_instruction_buffer.dut.imem tb_instruction_buffer.dut.instruction_1 tb_instruction_buffer.dut.instruction_2 tb_instruction_buffer.dut.pc_1 tb_instruction_buffer.dut.pc_2 tb_instruction_buffer.dut.program_counter
